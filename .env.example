NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for customer reservation submission and the protected owner tools.
# The public restaurant pages still render if these are unset; the reservation
# form then shows the documented telephone fallback and stores nothing.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional but required for owner alerts when an installed iPad web app is
# locked or the dashboard is in the background. Keep the private values only
# in server/deployment environment variables.
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:owner@example.com
PUSH_DISPATCH_SECRET=

# Customer reservation email. Gmail is the simplest free option: enable
# Google 2-Step Verification and use a 16-character App Password here. Never
# use or commit the Google account password. Resend is an alternative; when
# its two variables are set it takes priority over Gmail.
GMAIL_USER=
GMAIL_APP_PASSWORD=
RESEND_API_KEY=
RESERVATION_EMAIL_FROM=
RESERVATION_REPLY_TO=
RESERVATION_OWNER_EMAIL=
